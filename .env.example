# ── Required ──────────────────────────────────────────────────────────────────

# Path to your photos directory
# Linux/macOS: /home/username/Pictures
# Windows:     C:\Users\username\Pictures
PHOTOS_DIR=/home/user/Pictures

# ── Optional ──────────────────────────────────────────────────────────────────

# Web UI port (default: 8080)
PORT=8080

# Root directory for the folder browser in the web UI
# Linux/macOS: /home   (shows all home directories)
# Windows:     C:\Users
BROWSE_ROOT=/home

# Number of dominant colors to extract per image (default: 5)
NUM_COLORS=5

# Skip already-processed files — set to false to reprocess all (default: true)
SKIP_EXISTING=true

# OpenVINO device: NPU, GPU, or CPU (default: NPU with auto-fallback)
NPU_DEVICE=NPU
