# ── Optional ──────────────────────────────────────────────────────────────────

# Web UI port (default: 8080)
PORT=8080

# Number of dominant colors to extract per image (default: 5)
NUM_COLORS=5

# Skip already-processed files — set to false to reprocess all (default: true)
SKIP_EXISTING=true

# OpenVINO device: NPU, GPU, or CPU (default: NPU with auto-fallback)
NPU_DEVICE=NPU
